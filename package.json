{
  "name": "lean-mcp",
  "version": "0.1.0",
  "description": "Token and agent optimization MCP server for Claude — up to 90% context reduction",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lean-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "lint": "biome check src/",
    "format": "biome format --write src/"
  },
  "keywords": ["mcp", "claude", "token-optimization", "context", "ai"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "better-sqlite3": "^9.0.0",
    "@xenova/transformers": "^2.17.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
